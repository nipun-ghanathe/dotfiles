#!/bin/bash

selected=$(
	cat <<EOF | rofi -dmenu
Power off
Reboot
Lock
Log out
Suspend
Hibernate
EOF
)

case "$selected" in
	"Power off") systemctl poweroff ;;
	"Reboot") systemctl reboot ;;
	"Lock") hyprlock ;;
	"Log out") hyprctl dispatch 'hl.dsp.exit()' ;;
	"Suspend") systemctl suspend ;;
	"Hibernate") systemctl hibernate ;;
esac
