font=Inter 12
margin=20
padding=5
width=300
height=100
border-size=1
border-radius=6

on-notify=exec pw-play /usr/share/sounds/freedesktop/stereo/complete.oga

default-timeout=5000

background-color=#282c34
text-color=#979eab
progress-color=#393e48
border-color=#61afef

[urgency=low]
border-color=#98c379

[urgency=normal]
border-color=#61afef

[urgency=high]
border-color=#e06c75
